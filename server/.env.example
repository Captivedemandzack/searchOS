# Copy to .env.local and fill in secrets. Never commit .env.local.

DATABASE_URL="file:./dev.db"
API_PORT=8787

# Required — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Google OAuth (Google Cloud Console → OAuth 2.0 client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Anthropic (content generation)
ANTHROPIC_API_KEY=

# Optional
FRONTEND_URL=http://localhost:5173
PAGESPEED_API_KEY=
PEXELS_API_KEY=
