{
  "name": "groundwork-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Groundwork API — Fastify + Prisma/SQLite backend for the SEO operating system",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "seed": "tsx src/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && tsx src/seed.ts",
    "test": "tsx --test tests/*.test.ts",
    "migrate:urls": "tsx src/migrateUrls.ts",
    "validate:slk": "tsx src/scripts/validateSlk.ts",
    "recover:creds": "tsx src/scripts/recoverCreds.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.1",
    "google-auth-library": "^10.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
